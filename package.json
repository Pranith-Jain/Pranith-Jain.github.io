{
  "name": "pranith-jain-portfolio",
  "version": "2.0.0",
  "description": "Pranith Jain - Portfolio Website (React + Vite + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "wrangler dev --port 8787",
    "wiki:meta": "node scripts/extract-wiki-meta.mjs",
    "og:png": "node scripts/generate-og-png.mjs",
    "sitemap": "node scripts/build-sitemap.mjs",
    "prebuild": "node scripts/extract-wiki-meta.mjs && node scripts/generate-og-png.mjs && node scripts/build-sitemap.mjs",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "build:prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:server && npm run build:prerender",
    "check:budgets": "node scripts/check-budgets.mjs",
    "build:check": "npm run build && npm run check:budgets",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke.mjs",
    "smoke:slow": "node scripts/smoke.mjs --slow",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "analyze": "vite build --mode analyze",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.2",
    "agents": "^0.13.3",
    "dagre": "^0.8.5",
    "exifr": "^7.1.3",
    "isomorphic-dompurify": "^3.12.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "marked": "^14.1.4",
    "openpgp": "^6.3.0",
    "preact": "^10.29.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-globe.gl": "^2.38.0",
    "react-router-dom": "^6.22.3",
    "react-simple-maps": "^3.0.0",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.0.11",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.2",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^4.88.0"
  },
  "overrides": {
    "d3-color": "^3.1.0"
  },
  "keywords": [
    "portfolio",
    "react",
    "vite",
    "tailwind",
    "cybersecurity",
    "email-security",
    "threat-intelligence"
  ],
  "author": "Pranith Jain",
  "license": "MIT"
}

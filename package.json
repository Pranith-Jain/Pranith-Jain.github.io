{
  "name": "pranith-jain-portfolio",
  "version": "2.0.0",
  "description": "Pranith Jain - Portfolio Website (React + Vite + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-telegram-actor-catalog.mjs && vite",
    "dev:web": "vite",
    "dev:api": "wrangler dev --port 8787",
    "wiki:meta": "node scripts/extract-wiki-meta.mjs",
    "og:png": "node scripts/generate-og-png.mjs",
    "sitemap": "node scripts/build-sitemap.mjs",
    "check:meta": "node scripts/check-meta-lengths.mjs",
    "prebuild": "node scripts/build-telegram-actor-catalog.mjs && node scripts/extract-wiki-meta.mjs && node scripts/generate-og-png.mjs && node scripts/build-sitemap.mjs && node scripts/check-meta-lengths.mjs && node scripts/build-mcp-manifest.mjs && node scripts/build-llms-full.mjs",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "build:prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:server && npm run build:prerender",
    "check:budgets": "node scripts/check-budgets.mjs",
    "check:no-px-text": "node scripts/check-no-px-text.mjs",
    "build:check": "npm run build && npm run check:budgets",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/smoke.mjs",
    "smoke:slow": "node scripts/smoke.mjs --slow",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 244",
    "lint:fix": "eslint . --fix",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit --skipLibCheck",
    "typecheck:api": "node node_modules/typescript/bin/tsc --noEmit --skipLibCheck -p api/tsconfig.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "analyze": "vite build --mode analyze",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "prepare": "husky || true",
    "build:telegram-actor-catalog": "node scripts/build-telegram-actor-catalog.mjs",
    "test:mcp": "node --test scripts/build-mcp-manifest.test.mjs",
    "check:coverage": "node scripts/check-coverage.mjs",
    "check:all": "npm run lint && npm run typecheck && npm run typecheck:api && npm run test:run && npm run check:coverage",
    "test:cert-in": "node --test scripts/cert-in-diff.test.mjs",
    "test:scripts": "npm run test:mcp && npm run test:cert-in"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@xyflow/react": "^12.10.2",
    "agents": "^0.17.3",
    "dagre": "^0.8.5",
    "exifr": "^7.1.3",
    "html-to-image": "^1.11.13",
    "isomorphic-dompurify": "^3.18.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "marked": "^18.0.5",
    "openpgp": "^6.3.0",
    "preact": "^10.29.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-globe.gl": "^2.38.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.18.0",
    "react-simple-maps": "^3.0.0",
    "react-virtuoso": "^4.18.7",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^5.20260707.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.0.11",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "d3-color": "^3.1.0"
  },
  "keywords": [
    "portfolio",
    "react",
    "vite",
    "tailwind",
    "cybersecurity",
    "email-security",
    "threat-intelligence"
  ],
  "author": "Pranith Jain",
  "license": "MIT"
}

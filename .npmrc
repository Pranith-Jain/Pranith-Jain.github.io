# The Cloudflare Agents SDK (agents@0.13.x) declares a hard peer dependency on
# react@^19, but this app is intentionally on React 18. npm ci (used in CI) is
# strict about peer deps and fails with ERESOLVE without this. legacy-peer-deps
# accepts the existing (working) resolution already captured in package-lock.json
# — the same behavior used to install node_modules locally.
#
# Proper long-term fix: align versions (upgrade to React 19, or pin agents to a
# React-18-compatible release) and remove this.
legacy-peer-deps=true

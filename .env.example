# ── Case Study / Blog Pipeline ─────────────────────────────────────────
# Groq API key (free at console.groq.com) — primary LLM provider
GROQ_API_KEY=
# Google AI Studio key (free at aistudio.google.com) — Gemini fallback
GOOGLE_AI_STUDIO_API_KEY=
# NVIDIA API key (build.nvidia.com) — tertiary LLM fallback
NVIDIA_API_KEY=
# Master toggle for blog approval flow: "true" = drafts require admin approval
BLOG_APPROVAL_REQUIRED=
# Master toggle for social auto-posting: "true" = auto-post approved slots
SOCIAL_AUTOPOST_ENABLED=
# Max auto-posts per platform per cron tick (default 1)
SOCIAL_DRIP_PER_TICK=

# ── Admin ──────────────────────────────────────────────────────────────
# Shared secret for admin login (set via wrangler secret)
ADMIN_TOKEN=
# Increment to invalidate all admin sessions without rotating ADMIN_TOKEN
ADMIN_TOKEN_VERSION=

# ── X (Twitter) API ────────────────────────────────────────────────────
# OAuth 2.0 Bearer token — read-only (metrics, search)
X_API_BEARER_TOKEN=
# OAuth 1.0a credentials — posting as a user
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Cookie auth for the firehose (/api/v1/x-firehose)
X_AUTH_TOKEN=
X_CT0=

# ── LinkedIn API ──────────────────────────────────────────────────────
# OAuth 2.0 access token (w_member_social scope) for posting
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Notifications ──────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Threat Intel / OSINT Providers ─────────────────────────────────────
VT_API_KEY=               # VirusTotal
ABUSEIPDB_API_KEY=        # AbuseIPDB
SHODAN_API_KEY=           # Shodan
CENSYS_PAT=               # Censys
CENSYS_ORG_ID=
NETLAS_API_KEY=           # Netlas
IPINFO_TOKEN=             # IPinfo.io
IPQS_API_KEY=             # IP Quality Score
GREYNOISE_API_KEY=        # GreyNoise Community
PULSEDIVE_API_KEY=        # Pulsedive
CRIMINALIP_API_KEY=       # CriminalIP
KASPERSKY_API_KEY=        # Kaspersky OpenTip
CROWDSEC_API_KEY=         # CrowdSec CTI
POLYSWARM_API_KEY=        # PolySwarm
FULLHUNT_API_KEY=         # FullHunt
VULNCHECK_API_TOKEN=      # VulnCheck Community
VULNERS_API_KEY=          # Vulners
HIBP_API_KEY=             # Have I Been Pwned
HUNTER_API_KEY=           # Hunter.io (email)
EMAILREP_API_KEY=         # EmailRep.io
INTELX_API_KEY=           # IntelligenceX
ZOOMEYE_API_KEY=          # ZoomEye
INTODNS_API_KEY=          # IntoDNS.ai
PHISHTANK_API_KEY=        # PhishTank
TRACEIX_API_KEY=          # Traceix (hash AV lookup)
WHOXY_API_KEY=            # Whoxy (reverse WHOIS)
SPUR_API_KEY=             # Spur.us (proxy/VPN detection)
OSM_API_KEY=              # OpenSourceMalware
MALSHARE_API_KEY=         # MalShare
TRIAGE_API_KEY=           # tria.ge (malware sandbox)
HUDSONROCK_API_KEY=       # Hudson Rock (infostealer intel)
MYTHREATINTEL_API_TOKEN=  # MyThreatIntel REST API
PDCP_API_KEY=             # ProjectDiscovery Cloud Platform
NVD_API_KEY=              # NVD API (raises rate limit)
SERPAPI_API_KEY=          # SerpAPI (Google dorks)
RANSOMWARELIVE_API_KEY=   # ransomware.live PRO
PHANTOMCANDLE_USER=       # PhantomCandle threat intel
PHANTOMCANDLE_TOKEN=
GITHUB_TOKEN=             # GitHub PAT
CHAINABUSE_API_KEY=       # ChainAbuse (BTC)
NUMVERIFY_API_KEY=        # NumVerify (phone)
ABUSECH_AUTH_KEY=         # abuse.ch
GOOGLE_SAFE_BROWSING_API_KEY= # Google Safe Browsing
BUILTWITH_API_KEY=        # BuiltWith Domain API

# ── Cloudflare Bindings ────────────────────────────────────────────────
# AI binding (Workers AI) — set by wrangler, not a secret
# KV_CACHE - shared cache namespace
# SELF - service binding to self
# FEEDS_QUEUE - live-IOC fan-out queue
# CRON_LOCK_DO - durable object for cron locking
# REPORT_BUILDER - report generation DO
# INVESTIGATOR_AGENT - investigation agent DO
# LIVE_FEED_DO - WebSocket fan-out DO
# DFIR_MCP - MCP server DO
# RADAR_CRAWLER - radar deep-crawl DO
# GLOBAL_PULSE_DO - global pulse DO
# BRIEFINGS_DB - D1 database
# CASE_STUDIES - KV namespace
# ASSETS - static asset bucket
# BROWSER - Browser Run (Puppeteer) binding

# ── Frontend (Vite) ────────────────────────────────────────────────────
# API URL for the frontend (default: /api)
VITE_API_URL=/api
# Site URL for canonical links, RSS, etc.
SITE_URL=https://pranithjain.qzz.io

# ── Feature Flags ──────────────────────────────────────────────────────
# Set "true" to disable AI blog illustrations (cost control)
BLOG_AI_IMAGES_DISABLED=
# Allow localhost dev origins in CORS and auth checks
ALLOW_DEV_ORIGINS=
# Emergency valve — set "true" to allow public reads without API key
OPEN_PUBLIC_READS=
# Secret for signing internal tokens (HMAC-SHA256)
INTERNAL_TOKEN_SECRET=

# ── Infrastructure ─────────────────────────────────────────────────────
# Cloudflare zone ID + API token for cache purge operations
CF_ZONE_ID=
CF_API_TOKEN=
# Self-hosted file2txt bridge for PDF/DOCX extraction
FILE2TXT_BRIDGE_URL=
FILE2TXT_BRIDGE_TOKEN=
# Briefings admin endpoint bearer token
BRIEFINGS_ADMIN_TOKEN=
# Telegram bot token + channel for CTI archive / leak monitors
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_WEBHOOK_SECRET=

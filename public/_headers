# Security headers for all routes.
# Content-Security-Policy is INTENTIONALLY ABSENT here — the worker
# (worker/index.ts `withSecurityHeaders`) builds it per-response with a
# fresh nonce. Setting CSP here would race with the worker and freeze
# the policy at this static (unsafe-inline) string, defeating the nonce.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Hashed asset bundles never change — long immutable cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts are content-hashed (scripts/fetch-fonts.mjs) — cache forever
/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# fonts.css references content-hashed woff2, so it can't be immutable (a stale copy
# could point at a purged hash). But the Workers default (max-age=0, must-revalidate)
# render-blocks a 304 on every hard navigation. stale-while-revalidate serves it
# instantly from cache and refreshes in the background instead.
/fonts/fonts.css
  Cache-Control: public, max-age=600, stale-while-revalidate=86400

# Topojson is 190KB and stable; cache for a week
/world-110m.json
  Cache-Control: public, max-age=604800

# OG images: 100+ KB PNGs that rarely change (only on deploy)
/og-*.png
  Cache-Control: public, max-age=86400
/og-*.svg
  Cache-Control: public, max-age=86400

# PowerShell scripts — serve inline as text, not as downloads.
# Google Safe Browsing flags .ps1 files served without Content-Type
# as "harmful downloads". Setting text/plain prevents the download prompt.
/*.ps1
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
/data/si/scripts/*
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
